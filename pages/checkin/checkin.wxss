/* 拍照签到页面样式 */

page {
  background-color: #000;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #000;
}

/* 相机容器 */
.camera-container {
  position: relative;
  flex: 1;
  width: 100%;
  overflow: hidden;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 相机覆盖层 - 使用 cover-view */
.camera-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  pointer-events: none; /* 允许点击穿透到底层 */
}

/* 顶部信息栏 */
.camera-header {
  background: linear-gradient(to bottom, rgba(0,0,0,0.7), transparent);
  padding: 40rpx 30rpx 60rpx;
  pointer-events: auto;
}

.header-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 10rpx;
  align-items: center;
}

.header-label {
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  width: 80rpx;
}

.header-value {
  color: #fff;
  font-size: 26rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-value.warning {
  color: #ff9500;
}

/* 对焦框 - 透明背景 + 白色边框 */
.focus-frame {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 300rpx;
  height: 300rpx;
  pointer-events: none;
}

.focus-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: rgba(255,255,255,0.8);
  border-style: solid;
  background: transparent !important; /* 确保背景透明 */
}

.focus-corner.top-left {
  top: 0;
  left: 0;
  border-width: 4rpx 0 0 4rpx;
}

.focus-corner.top-right {
  top: 0;
  right: 0;
  border-width: 4rpx 4rpx 0 0;
}

.focus-corner.bottom-left {
  bottom: 0;
  left: 0;
  border-width: 0 0 4rpx 4rpx;
}

.focus-corner.bottom-right {
  bottom: 0;
  right: 0;
  border-width: 0 4rpx 4rpx 0;
}

/* 底部拍照区域 */
.camera-footer {
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: auto;
}

.tip-text {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.button-text {
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 拍照按钮 */
.photo-button {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255,255,255,0.8);
}

.photo-button.disabled {
  opacity: 0.5;
}

.photo-button-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #fff;
}

/* 预览区域 */
.preview-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #000;
}

.preview-image {
  flex: 1;
  width: 100%;
  background-color: #1a1a1a;
}

.photo-info {
  background-color: #1a1a1a;
  padding: 30rpx;
}

.photo-info-item {
  display: flex;
  margin-bottom: 15rpx;
}

.photo-info-item:last-child {
  margin-bottom: 0;
}

.photo-info-label {
  color: rgba(255,255,255,0.6);
  font-size: 28rpx;
  width: 100rpx;
}

.photo-info-value {
  color: #fff;
  font-size: 28rpx;
  flex: 1;
}

/* 工人选择器 */
.worker-selector {
  background-color: #1a1a1a;
  padding: 30rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.selector-label {
  display: block;
  color: rgba(255,255,255,0.8);
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.picker-box {
  background-color: rgba(255,255,255,0.1);
  border-radius: 10rpx;
  padding: 25rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
  font-size: 32rpx;
}

.picker-box.disabled {
  opacity: 0.5;
}

.picker-box .placeholder {
  color: rgba(255,255,255,0.5);
}

.picker-box .arrow {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
}

/* 底部操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  background-color: #1a1a1a;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 10rpx;
  font-size: 32rpx;
  text-align: center;
  border: none;
}

.btn-primary {
  background-color: #007AFF;
  color: #fff;
}

.btn-secondary {
  background-color: rgba(255,255,255,0.2);
  color: #fff;
}

/* 加载动画 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-box {
  background-color: rgba(255,255,255,0.9);
  padding: 40rpx 60rpx;
  border-radius: 12rpx;
}

.loading-box text {
  font-size: 30rpx;
  color: #333;
}
