/* 工人管理页面样式 */

/* 容器样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索框样式 */
.search-bar {
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  width: 100%;
  height: 60rpx;
  font-size: 32rpx;
  color: #333333;
  placeholder-color: #999999;
}

/* 工人列表样式 */
.workers-list {
  margin-bottom: 120rpx;
}

/* 工人项样式 */
.worker-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.worker-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 工人信息样式 */
.worker-info {
  flex: 1;
  margin-right: 20rpx;
}

.worker-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.worker-detail {
  font-size: 28rpx;
  color: #666666;
}

.detail-item {
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.label {
  color: #999999;
  margin-right: 10rpx;
}

.value {
  color: #333333;
}

/* 操作按钮样式 */
.worker-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  min-width: 120rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.edit-btn {
  background-color: #007AFF;
  color: #ffffff;
}

.delete-btn {
  background-color: #FF3B30;
  color: #ffffff;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999999;
}

.empty-text {
  display: block;
  font-size: 36rpx;
  margin-bottom: 20rpx;
}

.empty-hint {
  display: block;
  font-size: 28rpx;
}

/* 添加按钮样式 */
.add-btn {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  border-radius: 40rpx;
  background-color: #007AFF;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 表单样式 */
.form {
  padding: 20rpx 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 60rpx;
  font-size: 32rpx;
  color: #333333;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 15rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #007AFF;
  outline: none;
  box-shadow: 0 0 0 2rpx rgba(0, 122, 255, 0.1);
}

/* 模态框样式调整 */
.modal-content {
  padding: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx 20rpx;
}

.modal-footer button {
  flex: 1;
  margin: 0 10rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .worker-item {
    flex-direction: column;
  }
  
  .worker-actions {
    flex-direction: row;
    margin-top: 20rpx;
    justify-content: flex-end;
  }
  
  .action-btn {
    margin-left: 10rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.worker-item {
  animation: fadeIn 0.3s ease;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}