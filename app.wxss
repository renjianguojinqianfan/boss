/* 全局样式文件 */

/* 重置样式 */
page, view, text, input, button, image, navigator, scroll-view, swiper, picker, form, label, checkbox, radio {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 全局样式变量 */
page {
  /* 主色调 */
  --primary-color: #007AFF;
  --primary-light: #E3F2FD;
  --primary-dark: #0056b3;
  
  /* 辅助色调 */
  --secondary-color: #666666;
  --success-color: #4CD964;
  --warning-color: #FF9500;
  --danger-color: #FF3B30;
  --info-color: #5AC8FA;
  
  /* 背景色 */
  --background-color: #F5F5F5;
  --surface-color: #FFFFFF;
  --card-background: #FFFFFF;
  
  /* 文字颜色 */
  --text-color: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --text-inverse: #FFFFFF;
  
  /* 边框颜色 */
  --border-color: #E5E5E5;
  --border-light: #F0F0F0;
  --border-dark: #D0D0D0;
  
  /* 阴影 */
  --shadow-sm: 0 1rpx 3rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 12rpx;
  --radius-xl: 16rpx;
  --radius-full: 9999rpx;
  
  /* 字体大小 */
  --font-size-xs: 20rpx;
  --font-size-sm: 22rpx;
  --font-size-base: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  
  /* 字体权重 */
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  
  /* 动画 */
  --animation-duration: 0.3s;
  --animation-timing: ease-in-out;
  
  /* 基础样式 */
  background-color: var(--background-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: var(--font-size-base);
  color: var(--text-color);
  line-height: 1.5;
}

/* 容器样式 */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: var(--card-background);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-md);
  transition: all var(--animation-duration) var(--animation-timing);
}

.card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

/* 标题样式 */
.title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  margin-bottom: var(--spacing-md);
  color: var(--text-color);
}

/* 小标题样式 */
.subtitle {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-sm);
  color: var(--text-color);
}

/* 文本样式 */
.text {
  font-size: var(--font-size-base);
  line-height: 1.5;
  color: var(--text-color);
  margin-bottom: var(--spacing-xs);
}

/* 次要文本样式 */
.text-secondary {
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

/* 逆色文本样式 */
.text-inverse {
  color: var(--text-inverse);
}

/* 按钮样式 */
.btn {
  display: inline-block;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  text-align: center;
  cursor: pointer;
  transition: all var(--animation-duration) var(--animation-timing);
  position: relative;
  overflow: hidden;
}

/* 按钮按下效果 */
.btn:active {
  transform: translateY(2rpx);
  opacity: 0.9;
}

/* 主要按钮 */
.btn-primary {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  border: none;
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

/* 次要按钮 */
.btn-secondary {
  background-color: var(--surface-color);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  background-color: var(--primary-light);
}

/* 危险按钮 */
.btn-danger {
  background-color: var(--danger-color);
  color: var(--text-inverse);
  border: none;
}

.btn-danger:active {
  background-color: #d32f2f;
}

/* 成功按钮 */
.btn-success {
  background-color: var(--success-color);
  color: var(--text-inverse);
  border: none;
}

.btn-success:active {
  background-color: #388e3c;
}

/* 信息按钮 */
.btn-info {
  background-color: var(--info-color);
  color: var(--text-inverse);
  border: none;
}

.btn-info:active {
  background-color: #0288d1;
}

/* 警告按钮 */
.btn-warning {
  background-color: var(--warning-color);
  color: var(--text-inverse);
  border: none;
}

.btn-warning:active {
  background-color: #f57c00;
}

/* 轮廓按钮 */
.btn-outline {
  background-color: transparent;
  color: var(--text-color);
  border: 2rpx solid var(--border-color);
}

.btn-outline:active {
  background-color: var(--border-light);
}

/* 全宽按钮 */
.btn-full {
  width: 100%;
  margin-bottom: var(--spacing-md);
}

/* 小按钮 */
.btn-sm {
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-sm);
}

/* 大按钮 */
.btn-lg {
  padding: var(--spacing-lg) var(--spacing-xl);
  font-size: var(--font-size-md);
  border-radius: var(--radius-lg);
}

/* 圆形按钮 */
.btn-round {
  border-radius: var(--radius-full);
  padding: var(--spacing-md);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 按钮加载状态 */
.btn-loading {
  opacity: 0.7;
  pointer-events: none;
}

/* 输入框样式 */
.input {
  width: 100%;
  padding: var(--spacing-md);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  margin-bottom: var(--spacing-md);
  background-color: var(--surface-color);
  transition: all var(--animation-duration) var(--animation-timing);
  outline: none;
}

.input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.input::placeholder {
  color: var(--text-light);
  font-size: var(--font-size-sm);
}

.input:disabled {
  background-color: var(--border-light);
  border-color: var(--border-light);
  color: var(--text-light);
  cursor: not-allowed;
}

/* 输入框错误状态 */
.input-error {
  border-color: var(--danger-color);
}

.input-error:focus {
  box-shadow: 0 0 0 4rpx rgba(255, 59, 48, 0.1);
}

/* 输入框成功状态 */
.input-success {
  border-color: var(--success-color);
}

.input-success:focus {
  box-shadow: 0 0 0 4rpx rgba(76, 217, 100, 0.1);
}

/* 小输入框 */
.input-sm {
  padding: var(--spacing-sm);
  font-size: var(--font-size-sm);
}

/* 大输入框 */
.input-lg {
  padding: var(--spacing-lg);
  font-size: var(--font-size-md);
  border-radius: var(--radius-lg);
}

/* 标签样式 */
.label {
  display: block;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  margin-bottom: var(--spacing-xs);
  color: var(--text-color);
}

/* 标签小样式 */
.label-sm {
  font-size: var(--font-size-sm);
}

/* 标签大样式 */
.label-lg {
  font-size: var(--font-size-md);
  margin-bottom: var(--spacing-sm);
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--spacing-md) 0;
}

.divider-light {
  background-color: var(--border-light);
}

.divider-dark {
  background-color: var(--border-dark);
}

.divider-horizontal {
  width: 100%;
  height: 1rpx;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-xl);
}

.loading-small {
  padding: var(--spacing-md);
}

.loading-large {
  padding: calc(var(--spacing-xl) * 2);
}

.loading-text {
  margin-left: var(--spacing-sm);
  font-size: var(--font-size-base);
  color: var(--text-secondary);
}

/* 加载动画样式 */
.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border-light);
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-spinner-small {
  width: 24rpx;
  height: 24rpx;
  border-width: 3rpx;
}

.loading-spinner-large {
  width: 56rpx;
  height: 56rpx;
  border-width: 5rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: calc(var(--spacing-xl) * 2) var(--spacing-md);
  text-align: center;
  min-height: 400rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-icon-small {
  width: 80rpx;
  height: 80rpx;
}

.empty-icon-large {
  width: 160rpx;
  height: 160rpx;
}

.empty-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--text-color);
  margin-bottom: var(--spacing-sm);
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--text-light);
  line-height: 1.5;
  max-width: 400rpx;
}

.empty-action {
  margin-top: var(--spacing-lg);
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  background-color: var(--surface-color);
  border-bottom: 1rpx solid var(--border-color);
  transition: all var(--animation-duration) var(--animation-timing);
}

.list-item:active {
  background-color: var(--border-light);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--text-color);
  margin-bottom: var(--spacing-xs);
}

.list-item-subtitle {
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

.list-item-action {
  margin-left: var(--spacing-md);
}

/* 响应式网格 */
.row {
  display: flex;
  flex-wrap: wrap;
  margin: 0 calc(var(--spacing-xs) * -1);
}

.col {
  flex: 1;
  padding: 0 var(--spacing-xs);
  margin-bottom: var(--spacing-md);
}

.col-1 {
  flex: 0 0 8.333333%;
}

.col-2 {
  flex: 0 0 16.666667%;
}

.col-3 {
  flex: 0 0 25%;
}

.col-4 {
  flex: 0 0 33.333333%;
}

.col-6 {
  flex: 0 0 50%;
}

.col-8 {
  flex: 0 0 66.666667%;
}

.col-12 {
  flex: 0 0 100%;
}

/* 卡片统计样式 */
.stat-card {
  background-color: var(--card-background);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: var(--shadow-md);
  margin-bottom: var(--spacing-md);
  transition: all var(--animation-duration) var(--animation-timing);
}

.stat-card:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--primary-color);
  margin-bottom: var(--spacing-xs);
  line-height: 1;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.stat-card-primary {
  background-color: var(--primary-light);
  border: 1rpx solid var(--primary-color);
}

.stat-card-success {
  background-color: rgba(76, 217, 100, 0.1);
  border: 1rpx solid var(--success-color);
}

.stat-card-warning {
  background-color: rgba(255, 149, 0, 0.1);
  border: 1rpx solid var(--warning-color);
}

.stat-card-danger {
  background-color: rgba(255, 59, 48, 0.1);
  border: 1rpx solid var(--danger-color);
}

/* 相机容器样式 */
.camera-container {
  position: relative;
  width: 100%;
  height: 600rpx;
  background-color: #000000;
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.camera-container-sm {
  height: 400rpx;
  border-radius: var(--radius-md);
}

.camera-container-lg {
  height: 700rpx;
  border-radius: var(--radius-xl);
}

/* 水印样式 */
.watermark {
  position: absolute;
  bottom: var(--spacing-lg);
  left: var(--spacing-lg);
  right: var(--spacing-lg);
  color: var(--text-inverse);
  font-size: var(--font-size-base);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  text-align: center;
  background-color: rgba(0, 0, 0, 0.5);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-md);
}

.watermark-top {
  top: var(--spacing-lg);
  bottom: auto;
}

/* 底部操作栏 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--surface-color);
  padding: var(--spacing-md);
  border-top: 1rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bottom-action-safe {
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
}

.bottom-action-center {
  justify-content: center;
  gap: var(--spacing-lg);
}

.bottom-action-stacked {
  flex-direction: column;
  align-items: stretch;
  gap: var(--spacing-sm);
}

/* 选择器样式 */
.picker {
  width: 100%;
  padding: var(--spacing-md);
  background-color: var(--surface-color);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  margin-bottom: var(--spacing-md);
  transition: all var(--animation-duration) var(--animation-timing);
}

.picker:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx var(--primary-light);
}

.picker:disabled {
  background-color: var(--border-light);
  border-color: var(--border-light);
  color: var(--text-light);
  cursor: not-allowed;
}

/* 图片预览样式 */
.image-preview {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  transition: all var(--animation-duration) var(--animation-timing);
}

.image-preview:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.image-preview-sm {
  border-radius: var(--radius-sm);
}

.image-preview-lg {
  border-radius: var(--radius-lg);
}

/* 时间选择器样式 */
.date-picker {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.date-picker .text {
  margin-right: var(--spacing-md);
  margin-bottom: 0;
  flex-shrink: 0;
}

.date-picker-input {
  flex: 1;
  min-width: 200rpx;
}

/* 筛选器样式 */
.filter {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: var(--spacing-md);
  gap: var(--spacing-sm);
}

.filter-item {
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: var(--surface-color);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--text-color);
  transition: all var(--animation-duration) var(--animation-timing);
  cursor: pointer;
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-item.active {
  background-color: var(--primary-color);
  color: var(--text-inverse);
  border-color: var(--primary-color);
  box-shadow: var(--shadow-sm);
}

/* 提示样式 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background-color: rgba(0, 0, 0, 0.7);
  color: var(--text-inverse);
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  z-index: 9999;
  max-width: 80%;
  text-align: center;
  box-shadow: var(--shadow-lg);
}

/* 错误提示样式 */
.error {
  color: var(--danger-color);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

/* 成功提示样式 */
.success {
  color: var(--success-color);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

/* 警告提示样式 */
.warning {
  color: var(--warning-color);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

/* 信息提示样式 */
.info {
  color: var(--info-color);
  font-size: var(--font-size-sm);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

/* 底部安全区域适配 */
.safe-area {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-all {
  padding: env(safe-area-inset-top) 0 env(safe-area-inset-bottom) 0;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: var(--spacing-sm);
  }
  
  .card {
    padding: var(--spacing-md);
  }
  
  .stat-card {
    padding: var(--spacing-md);
  }
  
  .stat-value {
    font-size: var(--font-size-xl);
  }
  
  .bottom-action {
    padding: var(--spacing-sm);
  }
  
  /* 小屏幕字体调整 */
  .title {
    font-size: 28rpx;
  }
  
  .subtitle {
    font-size: 26rpx;
  }
  
  .text {
    font-size: 22rpx;
  }
  
  .text-secondary {
    font-size: 20rpx;
  }
}

/* 深色模式适配（如果需要） */
/* @media (prefers-color-scheme: dark) {
  深色模式样式可以在这里添加
} */

/* 动画效果 */
.fade-in {
  animation: fadeIn var(--animation-duration) var(--animation-timing);
}

.fade-out {
  animation: fadeOut var(--animation-duration) var(--animation-timing);
}

.slide-up {
  animation: slideUp var(--animation-duration) var(--animation-timing);
}

.slide-down {
  animation: slideDown var(--animation-duration) var(--animation-timing);
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    transform: translateY(-20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}