<!-- 工人管理页面 -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-bar">
    <input 
      type="text" 
      placeholder="搜索工人姓名、电话或部门" 
      bindinput="searchWorkers"
      class="search-input"
    />
  </view>

  <!-- 工人列表 -->
  <view class="workers-list">
    <block wx:for="{{workers}}" wx:key="id" wx:for-item="worker">
      <view class="worker-item">
        <view class="worker-info">
          <view class="worker-name">{{worker.name}}</view>
          <view class="worker-detail">
            <view class="detail-item">
              <text class="label">电话：</text>
              <text class="value">{{worker.phone}}</text>
            </view>
            <view class="detail-item">
              <text class="label">部门：</text>
              <text class="value">{{worker.department || '未设置'}}</text>
            </view>
            <view class="detail-item">
              <text class="label">职位：</text>
              <text class="value">{{worker.position || '未设置'}}</text>
            </view>
          </view>
        </view>
        <view class="worker-actions">
          <button 
            type="primary" 
            size="mini" 
            bindtap="openEditModal" 
            data-worker="{{worker}}"
            class="action-btn edit-btn"
          >
            编辑
          </button>
          <button 
            type="warn" 
            size="mini" 
            bindtap="deleteWorker" 
            data-id="{{worker.id}}"
            class="action-btn delete-btn"
          >
            删除
          </button>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view wx:if="{{workers.length === 0}}" class="empty-state">
      <text class="empty-text">暂无工人数据</text>
      <text class="empty-hint">点击下方按钮添加工人</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <button 
    type="primary" 
    bindtap="openAddModal"
    class="add-btn"
  >
    + 添加工人
  </button>
</view>
