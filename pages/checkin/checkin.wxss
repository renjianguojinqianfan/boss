/* 拍照签到页面样式 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 工人选择区域 */
.worker-section {
  width: 100%;
  margin-bottom: 30rpx;
  background-color: #ffffff;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.label {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333333;
}

.picker {
  width: 100%;
  height: 80rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
}

.picker-text {
  font-size: 30rpx;
  color: #333333;
}

/* 信息区域 */
.info-section {
  width: 100%;
  margin-bottom: 30rpx;
  background-color: #ffffff;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

/* 相机区域 */
.camera-section {
  width: 100%;
  margin-bottom: 30rpx;
  background-color: #000000;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.camera {
  width: 100%;
  height: 600rpx;
}

.camera-tip {
  padding: 20rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
}

/* 预览区域 */
.preview-section {
  width: 100%;
  margin-bottom: 30rpx;
  background-color: #ffffff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.preview-image {
  width: 100%;
  height: 600rpx;
  background-color: #f0f0f0;
}

.preview-tip {
  padding: 20rpx;
  background-color: #f9f9f9;
  color: #666666;
  font-size: 28rpx;
  text-align: center;
}

/* 按钮区域 */
.button-section {
  width: 100%;
  margin-bottom: 30rpx;
}

.button {
  width: 100%;
  height: 90rpx;
  font-size: 32rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.button-group {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.button-group .button {
  flex: 1;
  margin-bottom: 0;
}

.button.primary {
  background-color: #007AFF;
  color: #ffffff;
}

.button.secondary {
  background-color: #ffffff;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}

/* 加载动画 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.loading-content {
  background-color: #ffffff;
  padding: 40rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.3);
}

.loading-content text {
  font-size: 32rpx;
  color: #333333;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .camera {
    height: 500rpx;
  }
  
  .preview-image {
    height: 500rpx;
  }
  
  .button {
    height: 80rpx;
    font-size: 30rpx;
  }
}

@media (min-width: 768px) {
  .container {
    max-width: 600rpx;
    margin: 0 auto;
  }
  
  .camera {
    height: 700rpx;
  }
  
  .preview-image {
    height: 700rpx;
  }
}