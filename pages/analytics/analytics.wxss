/* 数据分析页面样式 */
.container {
  padding: 16rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 时间范围选择器 */
.time-range-selector {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.time-range-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.time-buttons {
  display: flex;
  gap: 12rpx;
}

.time-button {
  flex: 1;
  padding: 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  background-color: #fff;
  font-size: 28rpx;
  color: #666;
}

.time-button.active {
  background-color: #007AFF;
  color: #fff;
  border-color: #007AFF;
}

/* 数据概览卡片 */
.overview-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.overview-card {
  flex: 1;
  background-color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.card-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.card-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}
/* 工作时长统计区域 */
.duration-stats-section {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.duration-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.duration-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  background-color: #f8f9fa;
}

.duration-card.total {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.duration-card.full {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.duration-card.half {
  background: linear-gradient(135deg, #fa8c16 0%, #d46b08 100%);
}

.duration-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.duration-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.duration-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.duration-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.duration-value .unit {
  font-size: 24rpx;
  margin-left: 8rpx;
  opacity: 0.8;
}

/* 图表容器 */
.chart-container {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.chart-wrapper {
  height: 300rpx;
  position: relative;
}

.chart {
  width: 100%;
  height: 100%;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-content {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #007AFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #333;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .overview-cards {
    flex-direction: column;
  }
  
  .overview-card {
    width: 100%;
  }
  
  .chart-wrapper {
    height: 250rpx;
  }
}